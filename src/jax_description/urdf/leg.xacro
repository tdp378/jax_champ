<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="leg" params="
    name
    hip_x hip_y hip_z
    hip_axis_x
    upper_x upper_y upper_z
    lower_x lower_y lower_z
    foot_x foot_y foot_z

    hip_mesh upper_mesh lower_mesh foot_mesh

    hip_vis_x hip_vis_y hip_vis_z
    upper_vis_x upper_vis_y upper_vis_z
    lower_vis_x lower_vis_y lower_vis_z
    foot_vis_x foot_vis_y foot_vis_z

    hip_col_x hip_col_y hip_col_z
    upper_colmesh_x upper_colmesh_y upper_colmesh_z
    lower_colmesh_x lower_colmesh_y lower_colmesh_z
    foot_col_x foot_col_y foot_col_z

    hip_mass hip_com_x hip_com_y hip_com_z hip_ixx hip_ixy hip_ixz hip_iyy hip_iyz hip_izz
    upper_mass upper_com_x upper_com_y upper_com_z upper_ixx upper_ixy upper_ixz upper_iyy upper_iyz upper_izz
    lower_mass lower_com_x lower_com_y lower_com_z lower_ixx lower_ixy lower_ixz lower_iyy lower_iyz lower_izz
    foot_mass foot_com_x foot_com_y foot_com_z foot_ixx foot_ixy foot_ixz foot_iyy foot_iyz foot_izz
  ">

    <joint name="${name}_hip_joint" type="revolute">
      <origin xyz="${hip_x} ${hip_y} ${hip_z}" rpy="0 0 0"/>
      <parent link="trunk"/>
      <child link="${name}_hip_link"/>
      <axis xyz="${hip_axis_x} 0 0"/>
      <dynamics damping="${damping}" friction="${friction}"/>
      <limit lower="${hip_position_min}" upper="${hip_position_max}"
             effort="${hip_torque_max}" velocity="${hip_velocity_max}"/>
    </joint>

    <link name="${name}_hip_link">
      <visual>
        <origin xyz="${hip_vis_x} ${hip_vis_y} ${hip_vis_z}" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find jax_description)/meshes/${hip_mesh}"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 1.5708 0"/>
        <geometry>
          <cylinder radius="0.020" length="0.040"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="${hip_com_x} ${hip_com_y} ${hip_com_z}" rpy="0 0 0"/>
        <mass value="${hip_mass}"/>
        <inertia ixx="${hip_ixx}" ixy="${hip_ixy}" ixz="${hip_ixz}"
                 iyy="${hip_iyy}" iyz="${hip_iyz}" izz="${hip_izz}"/>
      </inertial>
    </link>

    <joint name="${name}_upper_leg_joint" type="revolute">
      <origin xyz="${upper_x} ${upper_y} ${upper_z}" rpy="0 0 0"/>
      <parent link="${name}_hip_link"/>
      <child link="${name}_upper_leg_link"/>
      <axis xyz="0 1 -0.000227"/>
      <dynamics damping="${damping}" friction="${friction}"/>
      <limit lower="${thigh_position_min}" upper="${thigh_position_max}"
             effort="${thigh_torque_max}" velocity="${thigh_velocity_max}"/>
    </joint>

    <link name="${name}_upper_leg_link">
      <visual>
        <origin xyz="${upper_vis_x} ${upper_vis_y} ${upper_vis_z}" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find jax_description)/meshes/${upper_mesh}"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="white"/>
      </visual>
      <collision>
        <origin xyz="0 0 -0.050" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.016" length="0.100"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="${upper_com_x} ${upper_com_y} ${upper_com_z}" rpy="0 0 0"/>
        <mass value="${upper_mass}"/>
        <inertia ixx="${upper_ixx}" ixy="${upper_ixy}" ixz="${upper_ixz}"
                 iyy="${upper_iyy}" iyz="${upper_iyz}" izz="${upper_izz}"/>
      </inertial>
    </link>

    <joint name="${name}_lower_leg_joint" type="revolute">
      <origin xyz="${lower_x} ${lower_y} ${lower_z}" rpy="0 0 0"/>
      <parent link="${name}_upper_leg_link"/>
      <child link="${name}_lower_leg_link"/>
      <axis xyz="0 1 -0.000227"/>
      <dynamics damping="${damping}" friction="${friction}"/>
      <limit lower="${calf_position_min}" upper="${calf_position_max}"
             effort="${calf_torque_max}" velocity="${calf_velocity_max}"/>
    </joint>

    <link name="${name}_lower_leg_link">
      <visual>
        <origin xyz="${lower_vis_x} ${lower_vis_y} ${lower_vis_z}" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find jax_description)/meshes/${lower_mesh}"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0.05 -0.010 -0.050" rpy="0 -0.73 0"/>
        <geometry>
          <cylinder radius="0.009" length="0.090"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="${lower_com_x} ${lower_com_y} ${lower_com_z}" rpy="0 0 0"/>
        <mass value="${lower_mass}"/>
        <inertia ixx="${lower_ixx}" ixy="${lower_ixy}" ixz="${lower_ixz}"
                 iyy="${lower_iyy}" iyz="${lower_iyz}" izz="${lower_izz}"/>
      </inertial>
    </link>

    <joint name="${name}_foot_joint" type="fixed">
      <origin xyz="${foot_x} ${foot_y} ${foot_z}" rpy="0 0 0"/>
      <parent link="${name}_lower_leg_link"/>
      <child link="${name}_foot_link"/>
    </joint>

    <link name="${name}_foot_link">
      <visual>
        <origin xyz="${foot_vis_x} ${foot_vis_y} ${foot_vis_z}" rpy="0 0 0"/>
        <geometry>
          <mesh filename="file://$(find jax_description)/meshes/${foot_mesh}"
                scale="0.001 0.001 0.001"/>
        </geometry>
        <material name="black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.040 0.025 0.015"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="${foot_com_x} ${foot_com_y} ${foot_com_z}" rpy="0 0 0"/>
        <mass value="${foot_mass}"/>
        <inertia ixx="${foot_ixx}" ixy="${foot_ixy}" ixz="${foot_ixz}"
                 iyy="${foot_iyy}" iyz="${foot_iyz}" izz="${foot_izz}"/>
      </inertial>
    </link>

  </xacro:macro>
</robot>